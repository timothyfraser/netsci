# Build artifacts
build/

# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo

# Plots produced by the example scripts (each script writes a .png in
# the current working directory for the reader to inspect). These are
# build artifacts, not source.
*.png
!docs/assets/*.png
# Figures embedded in the project sample report (generated, committed,
# served by the site). Rebuilt by scripts/build_sample_report_figures.py.
!docs/assignments/sample-report-fig*.png
# Project-dataset preview thumbnails (generated by data/projects/_make_thumbnails.py,
# committed, embedded in each dataset README + the catalog gallery).
!data/projects/**/thumb.png

# R
.Rhistory
.RData
.Rproj.user/
.Ruserdata
Rplots.pdf
*.pdf
# ...except the sample report PDF: a generated, committed deliverable the
# site links to. Rebuilt by scripts/build_sample_report.sh / CI.
!docs/assignments/sample-report.pdf

# Editors
.vscode/
.idea/
.DS_Store
runs/
logs/
.claude/settings.proposed.json
.claude/worktrees/
.harness-env-ready
.harness-env.lock
