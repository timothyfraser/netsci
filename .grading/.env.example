# Secrets live in ../.canvas/.env (gitignored). Copy these keys there:
#
# CANVAS_API_KEY=your_canvas_token
# CANVAS_COURSE_ID=87652
# LITELLM_API_KEY=your_cornell_ai_gateway_virtual_key
#
# Optional overrides:
# CANVAS_BASE_URL=https://canvas.cornell.edu
# LITELLM_BASE_URL=https://api.ai.it.cornell.edu
#
# Development / Playwright tests (no real API calls):
# MOCK_LLM=1
